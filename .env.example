# ============================================================================
#  VARIABLES D'ENVIRONNEMENT — copier ce fichier en `.env` et renseigner
# ----------------------------------------------------------------------------
#  Si ces variables sont ABSENTES, l'app démarre en MODE LOCAL (Dexie, code PIN)
#  — pratique pour la démo hors-ligne. Si elles sont présentes, l'app passe en
#  MODE SUPABASE (authentification e-mail + backend partagé + temps réel).
# ============================================================================

# URL du projet Supabase (Settings → API)
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co

# Clé publique "anon" (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Réservé aux scripts d'administration (NE PAS exposer côté app) ---------
# Clé service_role (Settings → API). Utilisée uniquement par scripts/creer-comptes.mjs
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
